DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=app
DB_USERNAME=app
DB_PASSWORD=app

# ───────────────────────────────────────────────
# AWS
# ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# CRM Configuration
CRM_BASE_URL=https://crm.egurrola.com/API
CRM_LOGIN_ENDPOINT=/Users/login
CRM_REFRESH_ENDPOINT=/Users/login
CRM_USERNAME=
CRM_PASSWORD=

SYNC_ENABLED=false

# Musi być IDENTYCZNY z define('CRM_MOBILE_SYNC_TOKEN', ...) w CRM config/config.php
CRM_MOBILE_SYNC_TOKEN=
CRM_PUSH_API_TOKEN=
# ───────────────────────────────────────────────
# SerwerSMS (OTP)

# ───────────────────────────────────────────────
SERWERSMS_TOKEN=
SERWERSMS_SENDER=mobile
SERWERSMS_URL=https://api2.serwersms.pl
SMS_APP_HASH=
SMS_TEST_MODE=false
CRM_PAYMENT_TOKEN_URL_TEMPLATE=https://app.paynow.pl/checkout?paymentId={token}
